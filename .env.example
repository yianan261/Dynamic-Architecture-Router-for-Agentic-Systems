# Copy to ".env" and fill in secrets (".env" is gitignored).
# python-dotenv loads this automatically from run_workbench_benchmark.py, etc.
#
# --- Backend: one of vllm | openai | google ---
LLM_BACKEND=vllm

# --- OpenAI (when LLM_BACKEND=openai) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_WORKER_MODEL=gpt-5.4-mini
# OPENAI_ROUTER_MODEL=gpt-5.4-mini

# --- Google Gemini (when LLM_BACKEND=google) ---
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
GOOGLE_WORKER_MODEL=gemini-3.1-flash-lite-preview
# GOOGLE_ROUTER_MODEL=gemini-3.1-flash-lite-preview

# --- vLLM / OpenAI-compatible local server (when LLM_BACKEND=vllm) ---
VLLM_WORKER_URL=http://localhost:8001/v1
VLLM_WORKER_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Optional: different provider for routing metadata only (vllm|openai|google)
# ROUTER_LLM_BACKEND=

# --- PCAB graphs (single_agent / centralized_mas) ---
USE_LLM_WORKERS=false
# USE_LLM_ROUTER=true
